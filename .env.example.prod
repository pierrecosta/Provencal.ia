# ============================================================================
# .env.example.prod — Variables d'environnement PRODUCTION
# Copier vers .env.prod sur le VPS et remplir les valeurs
# NE JAMAIS COMMITTER le fichier .env.prod rempli
# ============================================================================

# ── Domaine ─────────────────────────────────────────────────────────────
# Nom de domaine sans https://
DOMAIN=le-provencal.ovh

# ── PostgreSQL ──────────────────────────────────────────────────────────
# Utilisateur et mot de passe de la base de données
# Générer un mot de passe fort : openssl rand -base64 32
POSTGRES_USER=provencalia_prod
POSTGRES_PASSWORD=CHANGEME_GENERER_MOT_DE_PASSE_FORT
POSTGRES_DB=provencalia_prod

# ── Backend FastAPI ─────────────────────────────────────────────────────
# URL de connexion PostgreSQL (doit correspondre aux variables ci-dessus)
# "db" = nom du service Docker Compose (réseau interne)
DATABASE_URL=postgresql+asyncpg://provencalia_prod:CHANGEME_GENERER_MOT_DE_PASSE_FORT@db:5432/provencalia_prod

# Clé secrète JWT — OBLIGATOIRE : générer avec : openssl rand -hex 64
SECRET_KEY=CHANGEME_GENERER_CLE_SECRETE_LONGUE

# Algorithme JWT (ne pas modifier)
ALGORITHM=HS256

# Durée de validité du token JWT en minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Environnement — DOIT être "production" en prod
# Désactive Swagger/ReDoc, active les cookies Secure, etc.
ENVIRONMENT=production

# ── Frontend ────────────────────────────────────────────────────────────
# URL de l'API vue depuis le navigateur (avec https://)
VITE_API_URL=https://le-provencal.ovh

# ── Docker Hub (pull des images privées) ────────────────────────────────
# Token d'accès Docker Hub en lecture seule
# Créer sur https://hub.docker.com/settings/security → New Access Token (Read)
DOCKERHUB_USERNAME=pastaga
DOCKERHUB_TOKEN=CHANGEME_DOCKER_HUB_ACCESS_TOKEN

# ── Tag des images Docker ──────────────────────────────────────────────
# Tag à déployer (latest, sha-xxxxxx, v1.0.0…)
IMAGE_TAG=latest

# ── Let's Encrypt ──────────────────────────────────────────────────────
# Email pour les notifications de renouvellement de certificat
# Peut être un alias anonyme (ex: admin@le-provencal.ovh)
CERTBOT_EMAIL=admin@le-provencal.ovh

# ── Sauvegarde ──────────────────────────────────────────────────────────
# Répertoire local pour les dumps PostgreSQL
BACKUP_DIR=/opt/provencalia/backups

# Nombre de semaines de rétention des sauvegardes
BACKUP_RETENTION_WEEKS=4
